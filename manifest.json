{
  "manifest_version": 3,
  "name": "GlassHub",
  "version": "1.1",
  "description": "A beautiful, customizable glassmorphism new tab page.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "chrome_settings_overrides": {
    "homepage": "newtab.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "history"
  ],
  "host_permissions": [
    "*://suggestqueries.google.com/*",
    "*://api.open-meteo.com/*",
    "*://geocoding-api.open-meteo.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "glasshub@custom.extension",
      "strict_min_version": "143.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}